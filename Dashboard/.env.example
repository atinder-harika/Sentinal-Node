# ────────────────────────────────────────────────────────────────────────────
# Sentinel Node — environment variables
# Copy to `.env.local` and fill in the keys you need. Anything left empty
# falls back to a typed mock so the UI still runs.
# ────────────────────────────────────────────────────────────────────────────

# ── Google Cloud Vision (PRD §6.1, §7.1) ────────────────────────────────────
# Use ONE of these auth methods, not both:
#   1) API key (simplest for hackathon)
#   2) Service-account JSON (paste minified single-line JSON)
GCP_VISION_API_KEY=
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=

# ── Google Generative AI · Gemma / Gemini (PRD §6.2, §7.2) ──────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── ElevenLabs (PRD §6.4, §7.3) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Snowflake (PRD §6.3, §7.4) ──────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=SENTINEL
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=

# ── Auth0 (PRD §6.7) ────────────────────────────────────────────────────────
# AUTH0_SECRET: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Pi / Node 2 dispatch ────────────────────────────────────────────────────
# When the Pi is on the local Ethernet bridge, set this to its FastAPI URL.
# Example: http://192.168.137.50:8001/dispatch
NODE2_PUSH_URL=

# ── Vultr (PRD §6.5) ────────────────────────────────────────────────────────
# VULTR_API_KEY is only needed if you script provisioning. Not used at runtime.
VULTR_API_KEY=
